        "}"
    ],
    "persist": [
        "memstick",
        "assets",
        "demos"
    ],
    "checkver": {
        "url": "https://builds.ppsspp.org/meta/history.json",
        "regex": "v(?<version>[\\d.]+)-(?<build>[\\d]+)-g(?<commit>[\\da-fA-F]+)",
        "replace": "${version}-${build}-g${commit}"
    },
    "autoupdate": {
